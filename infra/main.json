{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Infrastructure template for ogrodnikprojektuje.pl. Provisions the Azure Static Web App, Azure Communication Services (email + comm service), a Flex Consumption Function App with its supporting storage accounts, and Application Insights. Custom domains are managed outside this template."
  },
  "parameters": {
    "projectName": {
      "type": "string",
      "defaultValue": "ogrodnikprojektuje",
      "metadata": {
        "description": "Base name used to derive most resource names."
      }
    },
    "staticSiteLocation": {
      "type": "string",
      "defaultValue": "West Europe",
      "metadata": {
        "description": "Location for the Azure Static Web App."
      }
    },
    "functionAppLocation": {
      "type": "string",
      "defaultValue": "Poland Central",
      "metadata": {
        "description": "Location for the Function App, App Service Plan, App Insights, and function storage account."
      }
    },
    "receiveStorageLocation": {
      "type": "string",
      "defaultValue": "Germany West Central",
      "metadata": {
        "description": "Location for the receive-mail storage account."
      }
    },
    "githubRepoUrl": {
      "type": "string",
      "defaultValue": "https://github.com/EasyL0ver/garden-portfolio",
      "metadata": {
        "description": "GitHub repository URL for the Static Web App."
      }
    },
    "githubBranch": {
      "type": "string",
      "defaultValue": "master",
      "metadata": {
        "description": "GitHub branch to deploy from."
      }
    },
    "siteHostname": {
      "type": "string",
      "defaultValue": "ogrodnikprojektuje.pl",
      "metadata": {
        "description": "Primary hostname of the site, used in CORS configuration (without scheme)."
      }
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the Log Analytics workspace to which Application Insights will send data. Required."
      }
    }
  },
  "variables": {
    "staticSiteName": "[parameters('projectName')]",
    "emailServiceName": "[concat(parameters('projectName'), '-email')]",
    "commServiceName": "[concat(parameters('projectName'), '-comm-service')]",
    "appServicePlanName": "[concat('ASP-', parameters('projectName'))]",
    "functionAppName": "form-functions",
    "functionStorageName": "[take(concat(toLower(replace(parameters('projectName'), '-', '')), uniqueString(resourceGroup().id)), 24)]",
    "receiveStorageName": "[take(concat('recv', uniqueString(resourceGroup().id)), 24)]",
    "appInsightsTagKey": "[concat('hidden-link: /app-insights-resource-id')]"
  },
  "resources": [
    {
      "type": "Microsoft.Communication/emailServices",
      "apiVersion": "2025-09-01",
      "name": "[variables('emailServiceName')]",
      "location": "global",
      "properties": {
        "dataLocation": "Germany"
      }
    },
    {
      "type": "Microsoft.Communication/emailServices/domains",
      "apiVersion": "2025-09-01",
      "name": "[concat(variables('emailServiceName'), '/AzureManagedDomain')]",
      "location": "global",
      "dependsOn": [
        "[resourceId('Microsoft.Communication/emailServices', variables('emailServiceName'))]"
      ],
      "properties": {
        "domainManagement": "AzureManaged",
        "userEngagementTracking": "Disabled"
      }
    },
    {
      "type": "Microsoft.Communication/emailServices/domains",
      "apiVersion": "2025-09-01",
      "name": "[concat(variables('emailServiceName'), '/', parameters('siteHostname'))]",
      "location": "global",
      "dependsOn": [
        "[resourceId('Microsoft.Communication/emailServices', variables('emailServiceName'))]"
      ],
      "properties": {
        "domainManagement": "CustomerManaged",
        "userEngagementTracking": "Disabled"
      }
    },
    {
      "type": "Microsoft.Communication/CommunicationServices",
      "apiVersion": "2025-09-01",
      "name": "[variables('commServiceName')]",
      "location": "global",
      "dependsOn": [
        "[resourceId('Microsoft.Communication/emailServices/domains', variables('emailServiceName'), 'AzureManagedDomain')]",
        "[resourceId('Microsoft.Communication/emailServices/domains', variables('emailServiceName'), parameters('siteHostname'))]"
      ],
      "properties": {
        "dataLocation": "germany",
        "linkedDomains": [
          "[resourceId('Microsoft.Communication/emailServices/domains', variables('emailServiceName'), 'AzureManagedDomain')]",
          "[resourceId('Microsoft.Communication/emailServices/domains', variables('emailServiceName'), parameters('siteHostname'))]"
        ]
      }
    },
    {
      "type": "microsoft.communication/emailservices/domains/senderusernames",
      "apiVersion": "2025-09-01",
      "name": "[concat(variables('emailServiceName'), '/AzureManagedDomain/donotreply')]",
      "dependsOn": [
        "[resourceId('microsoft.communication/emailservices/domains', variables('emailServiceName'), 'AzureManagedDomain')]",
        "[resourceId('microsoft.communication/emailservices', variables('emailServiceName'))]"
      ],
      "properties": {
        "displayName": "DoNotReply",
        "username": "DoNotReply"
      }
    },
    {
      "type": "microsoft.communication/emailservices/domains/senderusernames",
      "apiVersion": "2025-09-01",
      "name": "[concat(variables('emailServiceName'), '/', parameters('siteHostname'), '/biuro')]",
      "dependsOn": [
        "[resourceId('microsoft.communication/emailservices/domains', variables('emailServiceName'), parameters('siteHostname'))]",
        "[resourceId('microsoft.communication/emailservices', variables('emailServiceName'))]"
      ],
      "properties": {
        "displayName": "biuro",
        "username": "biuro"
      }
    },
    {
      "type": "microsoft.communication/emailservices/domains/senderusernames",
      "apiVersion": "2025-09-01",
      "name": "[concat(variables('emailServiceName'), '/', parameters('siteHostname'), '/donotreply')]",
      "dependsOn": [
        "[resourceId('microsoft.communication/emailservices/domains', variables('emailServiceName'), parameters('siteHostname'))]",
        "[resourceId('microsoft.communication/emailservices', variables('emailServiceName'))]"
      ],
      "properties": {
        "displayName": "DoNotReply",
        "username": "DoNotReply"
      }
    },
